<script src="<?autov('/plugins/folder.view3/scripts/include/jquery.multiselect.js')?>"></script>

<div class="canvas">
    <form onsubmit="submitForm(this); return false">
        <details class="fv3-section" open>
            <summary data-i18n="folder-basic">Basic</summary>
            <dl class="fv3-folder-settings">
                <dt data-i18n="name">Name:</dt>
                <dd>
                    <input type="text" name="name" pattern="[^\x00-\x1F\x7F<>&quot;'\\:]+" value="" required autocomplete="off">
                    <div id="fv3-name-warning" style="color: #e22828; font-size: 12px; display: none;">20 characters is the recommended maximum — longer names will be truncated/clipped.</div>
                </dd>

                <dt data-i18n="icon">Icon:</dt>
                <dd>
                    <img src="/plugins/dynamix.docker.manager/images/question.png" class="img" onerror="this.src='/plugins/dynamix.docker.manager/images/question.png';" style="width:48px;height:48px;">
                    <input type="text" name="icon" value="" oninput="updateIcon(this)">
                </dd>

                <dt data-i18n="folder-webui">Folder WebUI:</dt>
                <dd><input class="fv3-toggle" name="folder_webui" type="checkbox" onchange="updateForm()" /></dd>

                <dt constraint="folder-webui" class="fv3-setting-sub" style="display:none" data-i18n="folder-webui-url">WebUI URL:</dt>
                <dd constraint="folder-webui" style="display:none">
                    <input type="text" name="folder_webui_url" value="" placeholder="http://...">
                </dd>

                <dt data-i18n="regex">Regex:</dt>
                <dd><input type="text" name="regex" oninput="updateRegex(this)" value=""></dd>
            </dl>
        </details>

        <details class="fv3-section" open>
            <summary data-i18n="folder-preview-settings">Preview</summary>
            <dl class="fv3-folder-settings">
                <dt data-i18n="preview">Preview:</dt>
                <dd>
                    <select name="preview" onchange="updateForm()">
                        <option value="0" data-i18n="preview-option-0">None</option>
                        <option value="1" data-i18n="preview-option-1" selected>Icon and label</option>
                        <option value="2" data-i18n="preview-option-2">Only icon</option>
                        <option value="3" data-i18n="preview-option-3">Only label</option>
                        <option value="4" data-i18n="preview-option-4">List</option>
                    </select>
                </dd>

                <dt constraint="preview-1 preview-2 preview-3 preview-4" data-i18n="preview-hover">Show preview only on hover:</dt>
                <dd constraint="preview-1 preview-2 preview-3 preview-4"><input class="fv3-toggle" name="preview_hover" type="checkbox" /></dd>

                <dt constraint="preview-1 preview-3 preview-4 docker" data-i18n="preview-update">Orange text on update:</dt>
                <dd constraint="preview-1 preview-3 preview-4 docker"><input class="fv3-toggle" name="preview_update" type="checkbox" /></dd>

                <dt constraint="preview-1 preview-3 preview-4" data-i18n="preview-text-width">Text width:</dt>
                <dd constraint="preview-1 preview-3 preview-4"><input name="preview_text_width" type="text" /></dd>

                <dt constraint="preview-1 preview-2" data-i18n="preview-grayscale">Preview icon grayscale:</dt>
                <dd constraint="preview-1 preview-2"><input class="fv3-toggle" name="preview_grayscale" type="checkbox" /></dd>

                <dt constraint="preview-1 preview-2 preview-3 preview-4 docker" data-i18n="preview-webui">Add preview open WebUI:</dt>
                <dd constraint="preview-1 preview-2 preview-3 preview-4 docker"><input class="fv3-toggle" name="preview_webui" type="checkbox" /></dd>

                <dt constraint="preview-1 preview-2 preview-3 preview-4" data-i18n="preview-logs">Add preview open logs:</dt>
                <dd constraint="preview-1 preview-2 preview-3 preview-4"><input class="fv3-toggle" name="preview_logs" type="checkbox" /></dd>

                <dt constraint="preview-1 preview-2 preview-3 preview-4 docker" data-i18n="preview-console">Add preview open console:</dt>
                <dd constraint="preview-1 preview-2 preview-3 preview-4 docker"><input class="fv3-toggle" name="preview_console" type="checkbox" /></dd>

                <dt constraint="preview-1 preview-2 preview-3 preview-4" data-i18n="preview-vertical-bars">Preview vertical bars:</dt>
                <dd constraint="preview-1 preview-2 preview-3 preview-4"><input class="fv3-toggle" name="preview_vertical_bars" type="checkbox" onchange="updateForm()" /></dd>

                <dt constraint="bars-color" class="fv3-setting-sub" style="display:none" data-i18n="bars-color">Vertical bars color:</dt>
                <dd constraint="bars-color" style="display:none">
                    <input type="color" name="preview_vertical_bars_color" style="height:28px;">
                    <button class="fv3-color-reset" onclick="event.preventDefault(); $('div.canvas > form')[0].preview_vertical_bars_color.value = rgbToHex($('body').css('color'));"><i class="fa fa-repeat" aria-hidden="true"></i></button>
                </dd>

                <dt constraint="preview-1 preview-2 preview-3 preview-4" data-i18n="border">Show preview border:</dt>
                <dd constraint="preview-1 preview-2 preview-3 preview-4"><input class="fv3-toggle" name="preview_border" type="checkbox" onchange="updateForm()" /></dd>

                <dt constraint="border-color" class="fv3-setting-sub" style="display:none" data-i18n="border-color">Border color:</dt>
                <dd constraint="border-color" style="display:none">
                    <input type="color" name="preview_border_color" style="height:28px;">
                    <button class="fv3-color-reset" onclick="event.preventDefault(); $('div.canvas > form')[0].preview_border_color.value = rgbToHex($('body').css('color'));"><i class="fa fa-repeat" aria-hidden="true"></i></button>
                </dd>

                <dt constraint="preview-1 preview-2 preview-3 preview-4" data-i18n="preview-overflow">Preview overflow:</dt>
                <dd constraint="preview-1 preview-2 preview-3 preview-4">
                    <select name="preview_overflow" onchange="updateForm()">
                        <option value="0" data-i18n="preview-overflow-0" selected>Default</option>
                        <option value="1" data-i18n="preview-overflow-1">Expand row</option>
                        <option value="2" data-i18n="preview-overflow-2">Scroll</option>
                    </select>
                </dd>

                <dt constraint="overflow-expand" class="fv3-setting-sub" style="display:none" data-i18n="row-separator">Row separator:</dt>
                <dd constraint="overflow-expand" style="display:none"><input class="fv3-toggle" name="preview_row_separator" type="checkbox" onchange="updateForm()" /></dd>

                <dt constraint="separator-color" class="fv3-setting-sub" style="display:none" data-i18n="separator-color">Separator color:</dt>
                <dd constraint="separator-color" style="display:none">
                    <input type="color" name="preview_row_separator_color" style="height:28px;">
                    <button class="fv3-color-reset" onclick="event.preventDefault(); $('div.canvas > form')[0].preview_row_separator_color.value = rgbToHex($('body').css('color'));"><i class="fa fa-repeat" aria-hidden="true"></i></button>
                </dd>

                <dt constraint="preview-1 preview-2 preview-3 preview-4" data-i18n="lock-colors">Lock colors:</dt>
                <dd constraint="preview-1 preview-2 preview-3 preview-4"><input class="fv3-toggle" name="lock_colors" type="checkbox" /></dd>

                <dt constraint="docker preview-1 preview-2 preview-3 preview-4" data-i18n="context">Preview Context:</dt>
                <dd constraint="docker preview-1 preview-2 preview-3 preview-4">
                    <select name="context" onchange="updateForm()">
                        <option value="0" data-i18n="context-option-0">None</option>
                        <option value="1" data-i18n="context-option-1" selected>Default</option>
                        <option value="2" data-i18n="context-option-2">Advanced</option>
                    </select>
                </dd>

                <dt constraint="context-2 docker" class="fv3-setting-sub" style="display:none" data-i18n="context-trigger">Activation mode:</dt>
                <dd constraint="context-2 docker" style="display:none">
                    <select name="context_trigger">
                        <option value="0" data-i18n="context-trigger-option-0" selected>Click</option>
                        <option value="1" data-i18n="context-trigger-option-1">Hover</option>
                    </select>
                </dd>

                <dt constraint="context-2 docker" class="fv3-setting-sub" style="display:none" data-i18n="context-graph">Graph mode:</dt>
                <dd constraint="context-2 docker" style="display:none">
                    <select name="context_graph">
                        <option value="0" data-i18n="context-graph-option-0">None</option>
                        <option value="1" data-i18n="context-graph-option-1" selected>Combined</option>
                        <option value="2" data-i18n="context-graph-option-2">Split</option>
                        <option value="3" data-i18n="context-graph-option-3">CPU only</option>
                        <option value="4" data-i18n="context-graph-option-4">MEM only</option>
                    </select>
                </dd>

                <dt constraint="context_graph-1 context_graph-2 context_graph-3 context_graph-4 docker" class="fv3-setting-sub" style="display:none" data-i18n="context-graph-time">Time Frame (s):</dt>
                <dd constraint="context_graph-1 context_graph-2 context_graph-3 context_graph-4 docker" style="display:none">
                    <input type="number" name="context_graph_time" value="60">
                </dd>
            </dl>
        </details>

        <details class="fv3-section">
            <summary data-i18n="folder-behavior">Behavior</summary>
            <dl class="fv3-folder-settings">
                <dt constraint="docker" data-i18n="update-column">Hide update column:</dt>
                <dd constraint="docker"><input class="fv3-toggle" name="update_column" type="checkbox" /></dd>

                <dt data-i18n="override-default-actions">Override default actions:</dt>
                <dd><input class="fv3-toggle" name="override_default_actions" type="checkbox" /></dd>

                <dt data-i18n="default-action">Hide default action button:</dt>
                <dd><input class="fv3-toggle" name="default_action" type="checkbox" /></dd>

                <dt data-i18n="expand-tab">Expanded on Docker/VM tab:</dt>
                <dd><input class="fv3-toggle" name="expand_tab" type="checkbox" /></dd>

                <dt data-i18n="expand-dashboard">Expanded on Dashboard tab:</dt>
                <dd><input class="fv3-toggle" name="expand_dashboard" type="checkbox" /></dd>
            </dl>
        </details>

        <details class="fv3-section">
            <summary data-i18n="folder-custom-actions">Custom Actions</summary>
            <dl class="fv3-folder-settings">
                <dt data-i18n="custom-actions-folder">Custom actions:</dt>
                <dd><div class="custom-action-wrapper">​</div></dd>

                <dt>​</dt>
                <dd><a class="custom-action" data-i18n="[html]custom-action" onclick="customAction()"><i class="fa fa-plus" aria-hidden="true"></i> Add a custom action</a></dd>
            </dl>
        </details>

        <details class="fv3-section" open>
            <summary data-i18n="folder-containers">Containers / VMs</summary>
            <dl class="fv3-folder-settings">
                <dt data-i18n="order">Order:</dt>
                <dd class="fv3-order-dd">
                    <table class="sortable">
                        <thead>
                            <tr>
                                <th data-i18n="table-name">Name</th>
                                <th data-i18n="table-included">Included</th>
                                <th data-i18n="table-hide-preview">Hide Preview</th>
                            </tr>
                        </thead>
                        <tbody>
                        </tbody>
                    </table>
                </dd>
            </dl>
        </details>

        <span class="buttons-spaced">
            <input type="submit" value="Submit" data-i18n="[value]submit">
            <input type="button" value="Cancel" data-i18n="[value]cancel" onclick="cancelBtn()">
        </span>
    </form>
</div>

<script src="<?autov('/plugins/folder.view3/scripts/folder.js')?>" defer></script>

<div class="dialogCustomAction" style="display:none"></div>

<div class="templateDialogCustomAction" style="display: none;">
    <div>
        <dl>
            <dt data-i18n="name">Name:</dt>
            <dd>
                <input type="text" name="action_name">
            </dd>
        </dl>
    </div>
    <div>
        <dl>
            <dt data-i18n="custom-actions-type">Type:</dt>
            <dd>
                <select name="action_type" onchange="((el) => {$('[constraint*=\'action-type-\']').hide(); $(`[constraint*=\'action-type-${el.value}\']`).show();})(this)">
                    <option value="0" data-i18n="custom-actions-type-0">Standard</option>
                    <option value="1" data-i18n="custom-actions-type-1">Custom</option>
                </select>
            </dd>
        </dl>
    </div>
    <div class="standard" constraint="action-type-0">
        <div>
            <dl>
                <dt data-i18n="custom-actions-action">Action:</dt>
                <dd>
                    <select name="action_standard" onchange="((el) => {$('[constraint*=\'action-standard-\']').hide(); $(`[constraint*=\'action-standard-${el.value}\']`).show();})(this)">
                        <option value="0" data-i18n="custom-actions-action-0">Cycle</option>
                        <option value="1" data-i18n="custom-actions-action-1">Set</option>
                        <option value="2" data-i18n="custom-actions-action-2">Restart</option>
                    </select>
                </dd>
            </dl>
        </div>
        <div class="cycle" constraint="action-standard-0">
            <dl>
                <dt data-i18n="custom-actions-states">States:</dt>
                <dd>
                    <select name="action_cycle">
                        <option value="0" data-i18n="custom-actions-cycle-0">Start - stop</option>
                        <option value="1" data-i18n="custom-actions-cycle-1">Pause - resume</option>
                    </select>
                </dd>
            </dl>
        </div>
        <div class="set" style="display: none;" constraint="action-standard-1">
            <dl>
                <dt data-i18n="custom-actions-states">States:</dt>
                <dd>
                    <select name="action_set">
                        <option value="0" data-i18n="custom-actions-set-0">Start</option>
                        <option value="1" data-i18n="custom-actions-set-1">Stop</option>
                        <option value="2" data-i18n="custom-actions-set-2">Pause</option>
                        <option value="3" data-i18n="custom-actions-set-3">Resume</option>
                    </select>
                </dd>
            </dl>
        </div>
        <div class="action-subject">
            <dl>
                <dt data-i18n="custom-actions-cts">Conatiners:</dt>
                <dd>
                    <select name="action_elements" multiple></select>
                </dd>
            </dl>
        </div>
    </div>
    <div class="custom" style="display: none;" constraint="action-type-1">
        <dl>
            <dt data-i18n="custom-actions-script">Script:</dt>
            <dd>
                <input type="text" name="action_script">
            </dd>
        </dl>
        <dl>
            <dt data-i18n="custom-actions-arguments">Arguments:</dt>
            <dd>
                <input type="text" name="action_script_args">
            </dd>
        </dl>
        <dl>
            <dt data-i18n="custom-actions-script-sync">Sync:</dt>
            <dd>
            <input class="basic-switch-sync" name="action_script_sync" type="checkbox" />
            </dd>
        </dl>
    </div>
    <dl>
        <dt data-i18n="icon">Icon:</dt>
        <dd>
            <input type="text" name="action_script_icon">
        </dd>
    </dl>
</div>
